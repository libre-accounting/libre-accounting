{
  "git": {
    "tagName": "v${version}",
    "commitMessage": "Release v${version}",
    "requireCleanWorkingDir": true,
    "requireBranch": "main"
  },
  "github": {
    "release": true
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "after:bump": "node scripts/bump-version.js ${version} && git add config/version.php"
  }
}
